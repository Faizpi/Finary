{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "serve-server",
			"type": "shell",
			"command": "php",
			"args": [
				"server\\artisan",
				"serve",
				"--port=8000"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "dev-client",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--prefix",
				"client"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}